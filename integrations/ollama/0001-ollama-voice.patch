+// Package voice drives a local, CPU-only speech pipeline (Silero VAD ->
+// Parakeet STT -> Supertonic TTS) so the CLI can hold a spoken conversation
+// with a model. The heavy lifting lives in a small set of Bash/Python scripts
+// that are embedded into the binary and extracted on first use; this package
+// is a thin Go wrapper that shells out to them and wires Ollama-specific paths
+// (rooted at $HOME/.ollama/voice) via environment variables.
+//
+// The backends themselves (the ONNX STT/TTS HTTP servers on :5093 and :8766)
+// are installed by `ollama voice --setup`, which runs the embedded setup.sh.
+package voice
+
+import (
+	"bytes"
+	"context"
+	"crypto/sha256"
+	"embed"
+	"encoding/hex"
+	"fmt"
+	"io/fs"
+	"net"
+	"net/url"
+	"os"
+	"os/exec"
+	"path/filepath"
+	"runtime"
+	"strings"
+)
+
+//go:embed scripts
+var scriptsFS embed.FS
+
+// Default endpoints for the local STT/TTS backends. These match the defaults
+// baked into the scripts and installed by setup.sh, and can be overridden with
+// the STT_URL / SUPERTONIC_URL environment variables.
+const (
+	defaultSTTURL        = "http://127.0.0.1:5093/v1/audio/transcriptions"
+	defaultSupertonicURL = "http://127.0.0.1:8766"
+)
+
+// Root is the install/runtime directory for the voice stack.
+func Root() string {
+	if r := os.Getenv("OLLAMA_VOICE_HOME"); r != "" {
+		return r
+	}
+	home, err := os.UserHomeDir()
+	if err != nil {
+		home = "."
+	}
+	return filepath.Join(home, ".ollama", "voice")
+}
+
+func scriptsDir() string { return filepath.Join(Root(), "scripts") }
+
+// SetupScript returns the path to the extracted backend installer.
+func SetupScript() (string, error) {
+	if err := ensureScripts(); err != nil {
+		return "", err
+	}
+	return filepath.Join(scriptsDir(), "setup.sh"), nil
+}
+
+// ensureScripts extracts the embedded scripts to scriptsDir the first time, and
+// re-extracts whenever the embedded content changes (detected via a version
+// marker holding a hash of the bundle).
+func ensureScripts() error {
+	dir := scriptsDir()
+	want, err := bundleHash()
+	if err != nil {
+		return err
+	}
+
+	marker := filepath.Join(dir, ".bundle-version")
+	if got, err := os.ReadFile(marker); err == nil && strings.TrimSpace(string(got)) == want {
+		return nil
+	}
+
+	if err := os.MkdirAll(dir, 0o755); err != nil {
+		return err
+	}
+
+	entries, err := scriptsFS.ReadDir("scripts")
+	if err != nil {
+		return err
+	}
+	for _, e := range entries {
+		if e.IsDir() {
+			continue
+		}
+		data, err := scriptsFS.ReadFile("scripts/" + e.Name())
+		if err != nil {
+			return err
+		}
+		mode := fs.FileMode(0o644)
+		if strings.HasSuffix(e.Name(), ".sh") {
+			mode = 0o755
+		}
+		if err := os.WriteFile(filepath.Join(dir, e.Name()), data, mode); err != nil {
+			return err
+		}
+	}
+
+	return os.WriteFile(marker, []byte(want), 0o644)
+}
+
+func bundleHash() (string, error) {
+	h := sha256.New()
+	err := fs.WalkDir(scriptsFS, "scripts", func(path string, d fs.DirEntry, err error) error {
+		if err != nil || d.IsDir() {
+			return err
+		}
+		data, err := scriptsFS.ReadFile(path)
+		if err != nil {
+			return err
+		}
+		fmt.Fprintf(h, "%s\x00%x\n", path, sha256.Sum256(data))
+		return nil
+	})
+	if err != nil {
+		return "", err
+	}
+	return hex.EncodeToString(h.Sum(nil)), nil
+}
+
+// pythonPath returns the interpreter the scripts should use: the voice venv
+// created by the installer if present, otherwise the system python.
+func pythonPath() string {
+	if runtime.GOOS == "windows" {
+		venv := filepath.Join(Root(), "tts-venv", "Scripts", "python.exe")
+		if _, err := os.Stat(venv); err == nil {
+			return venv
+		}
+		return "python"
+	}
+	venv := filepath.Join(Root(), "tts-venv", "bin", "python3")
+	if _, err := os.Stat(venv); err == nil {
+		return venv
+	}
+	return "python3"
+}
+
+// talkCommand builds the command that runs a talk verb (listen/speak/status),
+// dispatching to talk.ps1 via PowerShell on Windows and talk.sh via bash
+// elsewhere.
+func talkCommand(ctx context.Context, verb string, extra ...string) *exec.Cmd {
+	if runtime.GOOS == "windows" {
+		args := append([]string{
+			"-NoProfile", "-ExecutionPolicy", "Bypass",
+			"-File", filepath.Join(scriptsDir(), "talk.ps1"), verb,
+		}, extra...)
+		return exec.CommandContext(ctx, "powershell", args...)
+	}
+	args := append([]string{filepath.Join(scriptsDir(), "talk.sh"), verb}, extra...)
+	return exec.CommandContext(ctx, "bash", args...)
+}
+
+// setupCommand builds the backend installer command for the current OS,
+// translating the cross-platform flags (--accel/--yes) to PowerShell on Windows.
+func setupCommand(ctx context.Context, accel string, yes bool) *exec.Cmd {
+	if runtime.GOOS == "windows" {
+		args := []string{
+			"-NoProfile", "-ExecutionPolicy", "Bypass",
+			"-File", filepath.Join(scriptsDir(), "setup.ps1"),
+			"-Accel", accel,
+		}
+		if yes {
+			args = append(args, "-Yes")
+		}
+		return exec.CommandContext(ctx, "powershell", args...)
+	}
+	args := []string{filepath.Join(scriptsDir(), "setup.sh"), "--accel", accel}
+	if yes {
+		args = append(args, "--yes")
+	}
+	return exec.CommandContext(ctx, "bash", args...)
+}
+
+// loadVoiceEnv parses the key=value file the installer writes at $BASE/voice.env
+// (acceleration choice and the resolved backend URLs). Missing file → empty map.
+func loadVoiceEnv() map[string]string {
+	m := map[string]string{}
+	data, err := os.ReadFile(filepath.Join(Root(), "voice.env"))
+	if err != nil {
+		return m
+	}
+	for _, line := range strings.Split(string(data), "\n") {
+		line = strings.TrimSpace(line)
+		if line == "" || strings.HasPrefix(line, "#") {
+			continue
+		}
+		if k, v, ok := strings.Cut(line, "="); ok {
+			m[strings.TrimSpace(k)] = strings.TrimSpace(v)
+		}
+	}
+	return m
+}
+
+// resolveURL returns the user's env value, then the installer's voice.env value,
+// then the built-in default.
+func resolveURL(key, def string) string {
+	if v := os.Getenv(key); v != "" {
+		return v
+	}
+	if v := loadVoiceEnv()[key]; v != "" {
+		return v
+	}
+	return def
+}
+
+// scriptEnv builds the environment for the scripts, pointing them at the
+// Ollama-rooted Python venv and the co-located helper scripts, and supplying
+// backend URL defaults unless the user has already set them.
+func scriptEnv(extra ...string) []string {
+	dir := scriptsDir()
+	env := os.Environ()
+
+	// Apply the installer's voice.env (accel, backend URLs, TTS engine) for any
+	// key the user hasn't overridden in their own environment.
+	fileEnv := loadVoiceEnv()
+	for k, v := range fileEnv {
+		if os.Getenv(k) == "" {
+			env = append(env, k+"="+v)
+		}
+	}
+
+	env = append(env,
+		"PYTHON="+pythonPath(),
+		"TTS_SH="+filepath.Join(dir, "tts.sh"),
+		"TTS_LANG_SH="+filepath.Join(dir, "tts_lang.sh"),
+	)
+	if os.Getenv("STT_URL") == "" && fileEnv["STT_URL"] == "" {
+		env = append(env, "STT_URL="+defaultSTTURL)
+	}
+	if os.Getenv("SUPERTONIC_URL") == "" && fileEnv["SUPERTONIC_URL"] == "" {
+		env = append(env, "SUPERTONIC_URL="+defaultSupertonicURL)
+	}
+	return append(env, extra...)
+}
+
+// Listen records one utterance, transcribes it, and returns the text. An empty
+// string (with a nil error) means silence or an idle timeout — the caller
+// should simply listen again rather than treat it as a failure.
+func Listen(ctx context.Context) (string, error) {
+	if err := ensureScripts(); err != nil {
+		return "", err
+	}
+	var out bytes.Buffer
+	cmd := talkCommand(ctx, "listen")
+	cmd.Env = scriptEnv()
+	cmd.Stdout = &out
+	cmd.Stderr = os.Stderr
+	cmd.Stdin = os.Stdin
+	if err := cmd.Run(); err != nil {
+		if ctx.Err() != nil {
+			return "", ctx.Err()
+		}
+		return "", fmt.Errorf("voice listen failed: %w", err)
+	}
+	return strings.TrimSpace(out.String()), nil
+}
+
+// Speak synthesizes text to speech and plays it. lang may be "" (auto-detect),
+// "en", or "es". Auto-listen is disabled so the caller owns the turn loop.
+func Speak(ctx context.Context, text, lang string) error {
+	text = strings.TrimSpace(text)
+	if text == "" {
+		return nil
+	}
+	if err := ensureScripts(); err != nil {
+		return err
+	}
+	var cmd *exec.Cmd
+	if lang != "" {
+		cmd = talkCommand(ctx, "speak", text, lang)
+	} else {
+		cmd = talkCommand(ctx, "speak", text)
+	}
+	cmd.Env = scriptEnv("TALK_AUTO_LISTEN=0")
+	cmd.Stdout = os.Stderr // diagnostics only; nothing useful on stdout
+	cmd.Stderr = os.Stderr
+	if err := cmd.Run(); err != nil {
+		if ctx.Err() != nil {
+			return ctx.Err()
+		}
+		return fmt.Errorf("voice speak failed: %w", err)
+	}
+	return nil
+}
+
+// Available reports whether both the STT and TTS backends are reachable. It is
+// used to print a helpful "run ollama voice --setup" hint instead of failing
+// deep inside a script.
+func Available() bool {
+	stt := resolveURL("STT_URL", defaultSTTURL)
+	tts := resolveURL("SUPERTONIC_URL", defaultSupertonicURL)
+	return reachable(stt) && reachable(tts)
+}
+
+func reachable(rawURL string) bool {
+	u, err := url.Parse(rawURL)
+	if err != nil {
+		return false
+	}
+	host := u.Host
+	if host == "" {
+		host = rawURL
+	}
+	if _, _, err := net.SplitHostPort(host); err != nil {
+		// no explicit port — assume default http port
+		host = net.JoinHostPort(host, "80")
+	}
+	conn, err := net.DialTimeout("tcp", host, 1_000_000_000) // 1s
+	if err != nil {
+		return false
+	}
+	_ = conn.Close()
+	return true
+}
+
+// Setup runs the embedded installer, which creates the voice venv and installs
+// and starts the Parakeet (STT) and Supertonic (TTS) backends under Root().
+// accel selects the acceleration path (auto|cpu|cuda|coreml); yes skips the
+// interactive prompt and accepts the auto-detected default.
+func Setup(ctx context.Context, accel string, yes bool) error {
+	if err := ensureScripts(); err != nil {
+		return err
+	}
+	if accel == "" {
+		accel = "auto"
+	}
+	cmd := setupCommand(ctx, accel, yes)
+	cmd.Env = scriptEnv()
+	cmd.Stdout = os.Stderr
+	cmd.Stderr = os.Stderr
+	cmd.Stdin = os.Stdin
+	if err := cmd.Run(); err != nil {
+		return fmt.Errorf("voice setup failed: %w", err)
+	}
+	return nil
+}
