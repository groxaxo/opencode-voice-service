--- /dev/null
+++ b/cmd/voice.go
@@ -0,0 +1,166 @@
+package cmd
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"net/http"
+	"os"
+	"os/signal"
+	"slices"
+	"syscall"
+	"time"
+
+	"github.com/spf13/cobra"
+
+	"github.com/ollama/ollama/api"
+	"github.com/ollama/ollama/types/model"
+	"github.com/ollama/ollama/voice"
+)
+
+// VoiceHandler runs a hands-free spoken conversation with a model: it records
+// an utterance, transcribes it (STT), sends it to the model via the same chat
+// round-trip used by `ollama run`, then speaks the reply (TTS) and loops.
+//
+// The speech pipeline runs entirely on CPU via local ONNX backends; this
+// handler only orchestrates listen -> chat -> speak. The backends are installed
+// with `ollama voice --setup`.
+func VoiceHandler(cmd *cobra.Command, args []string) error {
+	if setup, _ := cmd.Flags().GetBool("setup"); setup {
+		accel, _ := cmd.Flags().GetString("accel")
+		yes, _ := cmd.Flags().GetBool("yes")
+		return voice.Setup(cmd.Context(), accel, yes)
+	}
+
+	if len(args) < 1 {
+		return errors.New("voice requires a model: ollama voice MODEL (or: ollama voice --setup)")
+	}
+
+	// Talking to a model needs a running server (started on demand, like `run`).
+	if err := checkServerHeartbeat(cmd, args); err != nil {
+		return err
+	}
+
+	lang, _ := cmd.Flags().GetString("lang")
+	noSpeak, _ := cmd.Flags().GetBool("no-speak")
+
+	if !voice.Available() {
+		fmt.Fprint(os.Stderr, "Voice backends are not running.\n\nInstall and start them with:\n\n    ollama voice --setup\n\n")
+		return errors.New("voice backends unavailable")
+	}
+
+	opts := runOptions{
+		Model:    args[0],
+		Options:  map[string]any{},
+		WordWrap: os.Getenv("TERM") == "xterm-256color",
+	}
+
+	thinkFlag := cmd.Flags().Lookup("think")
+	if thinkFlag != nil && thinkFlag.Changed {
+		thinkStr, _ := cmd.Flags().GetString("think")
+		switch thinkStr {
+		case "", "true":
+			opts.Think = &api.ThinkValue{Value: true}
+		case "false":
+			opts.Think = &api.ThinkValue{Value: false}
+		case "high", "medium", "low", "max":
+			opts.Think = &api.ThinkValue{Value: thinkStr}
+		default:
+			return fmt.Errorf("invalid value for --think: %q (must be true, false, high, medium, low, or max)", thinkStr)
+		}
+	}
+
+	if keepAlive, _ := cmd.Flags().GetString("keepalive"); keepAlive != "" {
+		d, err := time.ParseDuration(keepAlive)
+		if err != nil {
+			return err
+		}
+		opts.KeepAlive = &api.Duration{Duration: d}
+	}
+
+	// Resolve model info, pulling the model if it isn't present locally.
+	client, err := api.ClientFromEnvironment()
+	if err != nil {
+		return err
+	}
+
+	name := args[0]
+	info, err := func() (*api.ShowResponse, error) {
+		info, err := client.Show(cmd.Context(), &api.ShowRequest{Name: name})
+		var se api.StatusError
+		if errors.As(err, &se) && se.StatusCode == http.StatusNotFound {
+			if err := PullHandler(cmd, []string{name}); err != nil {
+				return nil, err
+			}
+			return client.Show(cmd.Context(), &api.ShowRequest{Name: name})
+		}
+		return info, err
+	}()
+	if err != nil {
+		return err
+	}
+
+	if slices.Contains(info.Capabilities, model.CapabilityEmbedding) {
+		return errors.New("voice chat is not supported for embedding models")
+	}
+
+	opts.Think, err = inferThinkingOption(&info.Capabilities, &opts, thinkFlag != nil && thinkFlag.Changed)
+	if err != nil {
+		return err
+	}
+	applyShowResponseToRunOptions(&opts, info)
+
+	if err := loadOrUnloadModel(cmd, &opts); err != nil {
+		return err
+	}
+
+	// Ctrl-C exits the conversation loop (and interrupts any in-flight reply).
+	ctx, cancel := context.WithCancel(cmd.Context())
+	defer cancel()
+	sigChan := make(chan os.Signal, 1)
+	signal.Notify(sigChan, syscall.SIGINT)
+	go func() {
+		<-sigChan
+		cancel()
+	}()
+
+	fmt.Fprintf(os.Stderr, "Voice chat with %s — speak after the tone, Ctrl-C to exit.\n", opts.Model)
+
+	for {
+		if ctx.Err() != nil {
+			return nil
+		}
+
+		text, err := voice.Listen(ctx)
+		if err != nil {
+			if errors.Is(err, context.Canceled) {
+				return nil
+			}
+			return err
+		}
+		if text == "" {
+			continue // silence or idle timeout — keep listening
+		}
+
+		fmt.Printf(">>> %s\n", text)
+		opts.Messages = append(opts.Messages, api.Message{Role: "user", Content: text})
+
+		assistant, err := chat(cmd, opts)
+		if err != nil {
+			return err
+		}
+		if assistant == nil {
+			return nil // interrupted
+		}
+		opts.Messages = append(opts.Messages, *assistant)
+
+		if !noSpeak {
+			if err := voice.Speak(ctx, assistant.Content, lang); err != nil {
+				if errors.Is(err, context.Canceled) {
+					return nil
+				}
+				fmt.Fprintf(os.Stderr, "speak: %v\n", err)
+			}
+		}
+	}
+}
