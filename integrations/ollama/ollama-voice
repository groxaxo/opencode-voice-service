#!/usr/bin/env python3
# ollama-voice — hands-free spoken conversation with a local Ollama model.
#
# Pipeline:
#   mic --> Silero VAD --> Parakeet STT   (via `talk.sh listen`)
#       --> Ollama /api/chat              (your already-installed ollama)
#       --> local TTS                     (via `talk.sh speak`) --> playback --> loop
#
# It reuses the opencode-voice-service speech stack (talk.sh) for STT/TTS and the
# locally-installed Ollama HTTP API for the LLM. All speech inference is CPU-only;
# no GPU and no rebuild of Ollama are required — it talks to the stock binary over
# its stable HTTP API, exactly like `ollama run` does.
#
# Portable by design: it AUTO-DETECTS the local Supertonic TTS port at runtime
# (probing the project default :8766 then the common alt :8765), so it works on
# any machine without per-host configuration. It is self-contained — running it
# does not modify any other agent's install or your shell profile.
#
# Install:  ollama-voice --setup     (or: bash integrations/ollama/install.sh)
# Then:     ollama-voice [MODEL]
#
# Usage:
#   ollama-voice                  talk to the default model (speak after the tone)
#   ollama-voice MODEL            talk to a specific model (pulled if missing)
#   ollama-voice --setup          install/repair the voice backends + this command
#   ollama-voice --text           type instead of speaking (replies still spoken)
#   ollama-voice --once           one exchange, then exit
#   ollama-voice --no-speak       print replies but do not synthesize them
#   ollama-voice --list           list local Ollama models and exit
#   ollama-voice --status         check Ollama + STT/TTS backends and exit
#   Ctrl-C                        leave the conversation
#
# Environment:
#   OLLAMA_HOST            Ollama endpoint            (default http://127.0.0.1:11434)
#   OLLAMA_VOICE_MODEL     default model when none is given on the command line
#   OLLAMA_VOICE_THINK     false|true|high|medium|low|default  (default: false —
#                          reasoning is never spoken aloud; "default" lets the model decide)
#   OLLAMA_VOICE_SYSTEM    system prompt (default: a concise spoken-style prompt;
#                          set to an empty string to use the model's own system prompt)
#   OLLAMA_VOICE_LANG      en|es|""   TTS language hint (default: auto-detect)
#   OLLAMA_VOICE_KEEPALIVE keep-alive for the model, e.g. 10m (default: server default)
#   OLLAMA_VOICE_NUM_PREDICT  cap reply length in tokens (default 400; 0 = unlimited)
#   OLLAMA_VOICE_HISTORY   conversation messages to keep for context (default 20; 0 = all)
#   OLLAMA_VOICE_NO_DETECT 1 to skip TTS port auto-detection (trust env/talk.sh defaults)
#   OLLAMA_VOICE_ENV       KEY=VALUE defaults file applied when those keys are unset
#                          (default ~/.config/opencode/ollama-voice.env; auto-written cache)
#   TALK_SH                path to talk.sh (default: the installed copy)
#   TALK_IDLE_TIMEOUT_S, VAD_THRESHOLD, MIC_QUERY, TTS_ENGINE, SUPERTONIC_URL, ...
#                          forwarded to talk.sh unchanged (an explicit value wins over detection).

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request

OMIT = object()  # sentinel: "do not send this field"

DEFAULT_HOST = "http://127.0.0.1:11434"
# Candidate local Supertonic ports, tried in order during auto-detection. :8766 is
# the project default; :8765 is the common alternative when another service holds 8766.
SUPERTONIC_CANDIDATES = ("http://127.0.0.1:8766", "http://127.0.0.1:8765")
NEUTTS_URL = "http://127.0.0.1:8020"

DEFAULT_SYSTEM = (
    "You are a helpful voice assistant. The user is speaking to you out loud, and "
    "your reply will be read back by a text-to-speech engine. Answer in a natural, "
    "conversational, spoken style and keep it short — usually one to three sentences. "
    "Do not use markdown, bullet lists, headings, code blocks, tables, or emoji; write "
    "plain spoken sentences. If you need to refer to code or a link, describe it briefly "
    "instead of reading it out character by character."
)

EXIT_PHRASES = {
    "goodbye", "good bye", "bye", "bye bye", "exit", "quit", "stop", "stop talking",
    "end conversation", "that's all", "thats all", "thank you goodbye",
    "adios", "adiós", "chau", "chao", "hasta luego", "nos vemos",
}

ENV_FILE = os.environ.get("OLLAMA_VOICE_ENV") or os.path.expanduser(
    "~/.config/opencode/ollama-voice.env")

_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(code, text):
    return "\033[%sm%s\033[0m" % (code, text) if _USE_COLOR else text


def info(msg):
    sys.stderr.write(_c("1;34", "[voice] ") + msg + "\n"); sys.stderr.flush()


def warn(msg):
    sys.stderr.write(_c("1;33", "[voice] ") + msg + "\n"); sys.stderr.flush()


def fail(msg, code=1):
    sys.stderr.write(_c("1;31", "[voice] ") + msg + "\n"); sys.stderr.flush()
    sys.exit(code)


def load_env_defaults():
    """Apply KEY=VALUE defaults from the env file (real environment always wins)."""
    try:
        fh = open(ENV_FILE, "r", encoding="utf-8")
    except OSError:
        return
    with fh:
        for line in fh:
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            key, value = key.strip(), value.strip()
            if key and os.environ.get(key) is None:
                os.environ[key] = value


# --------------------------------------------------------------------------- #
# Locating the speech stack (talk.sh)                                          #
# --------------------------------------------------------------------------- #

def find_talk_sh():
    candidates = [os.environ.get("TALK_SH"),
                  os.path.expanduser("~/.config/opencode/skills/talk/talk.sh")]
    here = os.path.dirname(os.path.abspath(__file__))
    candidates.append(os.path.normpath(os.path.join(here, "..", "..", "service", "talk.sh")))
    for path in candidates:
        if path and os.path.isfile(path):
            return path
    fail("Voice scripts (talk.sh) not found.\n"
         "        Install the voice backends first:  ollama-voice --setup\n"
         "        or point this tool at an existing talk.sh with TALK_SH=/path/to/talk.sh")


def listen(talk_sh):
    """Record one utterance and return the transcript ("" on silence/timeout)."""
    sys.stderr.write(_c("1;36", "\n● listening — speak now…\n")); sys.stderr.flush()
    try:
        proc = subprocess.run(["bash", talk_sh, "listen"], stdout=subprocess.PIPE,
                              stderr=None, text=True)
    except FileNotFoundError:
        fail("`bash` not found on PATH — cannot run the speech scripts.")
    if proc.returncode != 0:
        warn("listen failed (talk.sh exit %d) — is the STT backend on :5093 up?" % proc.returncode)
        return ""
    return (proc.stdout or "").strip()


def speak(talk_sh, text, lang):
    """Synthesize and play text. Auto-listen is disabled; we own the turn loop."""
    text = text.strip()
    if not text:
        return
    args = ["bash", talk_sh, "speak", text] + ([lang] if lang else [])
    env = dict(os.environ)
    env["TALK_AUTO_LISTEN"] = "0"
    try:
        proc = subprocess.run(args, env=env)
    except FileNotFoundError:
        fail("`bash` not found on PATH — cannot run the speech scripts.")
    if proc.returncode != 0:
        warn("speak failed (talk.sh exit %d) — is a TTS backend reachable?" % proc.returncode)


# --------------------------------------------------------------------------- #
# Local TTS auto-detection (portable: works on any machine)                    #
# --------------------------------------------------------------------------- #

def _supertonic_synthesizes(url, timeout=8):
    """True iff url is a Supertonic server: POST /v1/audio/speech returns WAV (RIFF)."""
    body = json.dumps({
        "input": "hi", "voice": os.environ.get("SUPERTONIC_VOICE", "F4"),
        "response_format": "wav", "stream": False,
        "total_steps": 2, "speed": 1.0, "lang_code": "en",
    }).encode("utf-8")
    req = urllib.request.Request(url.rstrip("/") + "/v1/audio/speech", data=body,
                                 headers={"Content-Type": "application/json"}, method="POST")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.read(4) == b"RIFF"
    except Exception:
        return False


def _cache_tts_choice(engine, url):
    """Persist the detected engine/URL so the next run starts fast (TTS keys only)."""
    try:
        os.makedirs(os.path.dirname(ENV_FILE), exist_ok=True)
        lines = ["# ollama-voice TTS defaults — auto-detected; delete to re-detect.",
                 "# Your shell environment overrides anything here.",
                 "TTS_ENGINE=%s" % engine]
        if url:
            lines.append("SUPERTONIC_URL=%s" % url)
        with open(ENV_FILE, "w", encoding="utf-8") as f:
            f.write("\n".join(lines) + "\n")
    except OSError:
        pass


def detect_local_tts():
    """Pick a working LOCAL TTS on any machine and export it (engine + URL).

    Respects an explicit non-local engine choice and the OLLAMA_VOICE_NO_DETECT
    opt-out. Otherwise probes the candidate Supertonic ports (the one already
    set/cached first, then :8766, then :8765) for a server that actually returns
    audio, caches the winner, and prefers local NeuTTS before the xAI cloud. This
    is what makes local-first TTS work portably without per-host shell config.
    """
    if os.environ.get("OLLAMA_VOICE_NO_DETECT") == "1":
        return
    engine = (os.environ.get("TTS_ENGINE") or "").lower()
    if engine and engine not in ("supertonic", "coreml-tts"):
        return  # user explicitly picked neutts/xai — honor it

    candidates = []
    for url in (os.environ.get("SUPERTONIC_URL"),) + SUPERTONIC_CANDIDATES:
        if url and url.rstrip("/") not in candidates:
            candidates.append(url.rstrip("/"))

    for url in candidates:
        if _supertonic_synthesizes(url):
            os.environ["TTS_ENGINE"] = "supertonic"
            os.environ["SUPERTONIC_URL"] = url
            _cache_tts_choice("supertonic", url)
            info("Local TTS: Supertonic at %s" % url)
            return

    if reachable(NEUTTS_URL + "/"):
        os.environ["TTS_ENGINE"] = "neutts"
        _cache_tts_choice("neutts", None)
        info("Local TTS: NeuTTS (:8020) — Supertonic not found on :8766/:8765")
        return

    warn("No local TTS found (:8766/:8765 Supertonic, :8020 NeuTTS) — talk.sh's chain "
         "applies (xAI cloud only as a last resort).")


# --------------------------------------------------------------------------- #
# Ollama HTTP API                                                              #
# --------------------------------------------------------------------------- #

class OllamaError(Exception):
    pass


def _normalize_host(host):
    host = (host or DEFAULT_HOST).strip().rstrip("/")
    if not re.match(r"^https?://", host):
        host = "http://" + host
    return host


def _request(host, path, payload=None, timeout=10):
    url = host + path
    data = json.dumps(payload).encode("utf-8") if payload is not None else None
    headers = {"Content-Type": "application/json"} if data else {}
    req = urllib.request.Request(url, data=data, headers=headers,
                                 method="POST" if data else "GET")
    try:
        return urllib.request.urlopen(req, timeout=timeout)
    except urllib.error.HTTPError as e:
        body = ""
        try:
            body = e.read().decode("utf-8", "replace")
        except Exception:
            pass
        msg = body
        try:
            msg = json.loads(body).get("error", body)
        except Exception:
            pass
        raise OllamaError("HTTP %d: %s" % (e.code, (msg or "").strip() or e.reason))
    except urllib.error.URLError as e:
        raise OllamaError("cannot reach Ollama at %s (%s)" % (host, e.reason))


def server_up(host):
    try:
        _request(host, "/api/version", timeout=3).read()
        return True
    except OllamaError:
        return False


def server_version(host):
    try:
        data = json.loads(_request(host, "/api/version", timeout=3).read().decode("utf-8"))
        return data.get("version", "?")
    except Exception:
        return None


def list_models(host):
    try:
        data = json.loads(_request(host, "/api/tags", timeout=5).read().decode("utf-8"))
    except OllamaError:
        return []
    return [m.get("name", "") for m in data.get("models", []) if m.get("name")]


def model_present(host, model):
    base = model.split(":")[0]
    for n in list_models(host):
        if n == model or n == model + ":latest" or n.split(":")[0] == base:
            return True
    return False


def try_start_server(host):
    if server_up(host):
        return True
    exe = shutil.which("ollama")
    if not exe:
        return False
    info("Ollama is not running — starting `ollama serve`…")
    try:
        logf = open(os.path.expanduser("~/.ollama/voice-serve.log"), "ab")
    except Exception:
        logf = subprocess.DEVNULL
    try:
        subprocess.Popen([exe, "serve"], stdout=logf, stderr=logf,
                         stdin=subprocess.DEVNULL, start_new_session=True)
    except Exception as e:
        warn("could not start ollama serve: %s" % e)
        return False
    for _ in range(24):  # up to ~12s
        if server_up(host):
            return True
        time.sleep(0.5)
    return server_up(host)


def ensure_model(host, model):
    if model_present(host, model):
        return
    exe = shutil.which("ollama")
    if not exe:
        raise OllamaError("model '%s' is not installed and `ollama` is not on PATH to pull it" % model)
    info("Model '%s' is not installed locally — pulling it now…" % model)
    if subprocess.call([exe, "pull", model]) != 0:
        raise OllamaError("`ollama pull %s` failed" % model)


# --------------------------------------------------------------------------- #
# Cleaning model output for speech                                             #
# --------------------------------------------------------------------------- #

def clean_for_speech(text):
    """Strip reasoning/markup so the TTS reads natural prose, not symbols."""
    if not text:
        return ""
    # Never speak chain-of-thought — handle complete blocks, a stray leading close,
    # and a truncated/unclosed trailing open (covers inline + streamed reasoning).
    text = re.sub(r"<think>.*?</think>", " ", text, flags=re.S | re.I)
    text = re.sub(r"<thinking>.*?</thinking>", " ", text, flags=re.S | re.I)
    text = re.sub(r"^.*?</think>", " ", text, flags=re.S | re.I)
    text = re.sub(r"<think>.*$", " ", text, flags=re.S | re.I)
    # Code blocks are shown on screen; speaking them is useless.
    text = re.sub(r"```.*?```", " . Code is shown on screen. ", text, flags=re.S)
    text = re.sub(r"~~~.*?~~~", " . Code is shown on screen. ", text, flags=re.S)
    text = re.sub(r"`([^`]*)`", r"\1", text)                 # inline code -> bare text
    text = re.sub(r"!\[[^\]]*\]\([^)]*\)", " ", text)        # images
    text = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", text)     # links -> link text
    lines = []
    for ln in text.splitlines():
        ln = re.sub(r"^\s{0,3}#{1,6}\s*", "", ln)            # headings
        ln = re.sub(r"^\s*>\s?", "", ln)                     # blockquotes
        ln = re.sub(r"^\s*[-*+]\s+", "", ln)                 # bullets
        ln = re.sub(r"^\s*\d+[.)]\s+", "", ln)               # numbered lists
        lines.append(ln)
    text = "\n".join(lines)
    text = text.replace("**", "").replace("__", "")          # bold
    text = re.sub(r"(?<!\w)[*_](?=\w)", "", text)            # opening emphasis
    text = re.sub(r"(?<=\w)[*_](?!\w)", "", text)            # closing emphasis
    text = re.sub(r"\s*\n\s*", ". ", text)                   # line breaks -> sentence breaks
    text = re.sub(r"\s{2,}", " ", text)
    text = re.sub(r"(?:\.\s*){2,}", ". ", text)              # collapse runs of periods
    return text.strip()


def is_exit_phrase(text):
    return re.sub(r"^\W+|\W+$", "", text.lower()).strip() in EXIT_PHRASES


# --------------------------------------------------------------------------- #
# Conversation                                                                 #
# --------------------------------------------------------------------------- #

class Conversation:
    def __init__(self, host, model, system, think, keep_alive, num_predict, history_limit):
        self.host = host
        self.model = model
        self.has_system = bool(system)
        self.messages = [{"role": "system", "content": system}] if system else []
        self.think = think
        self.think_unsupported = False
        self.keep_alive = keep_alive
        self.options = {"num_predict": num_predict} if num_predict else {}
        self.history_limit = history_limit  # non-system messages to keep (0 = all)

    def _trim(self):
        if not self.history_limit:
            return
        head = self.messages[:1] if self.has_system else []
        tail = self.messages[1:] if self.has_system else self.messages
        if len(tail) > self.history_limit:
            self.messages = head + tail[-self.history_limit:]

    def _build_payload(self):
        payload = {"model": self.model, "messages": self.messages, "stream": True}
        if self.think is not OMIT and not self.think_unsupported:
            payload["think"] = self.think
        if self.options:
            payload["options"] = self.options
        if self.keep_alive:
            payload["keep_alive"] = self.keep_alive
        return payload

    def _stream_once(self):
        resp = _request(self.host, "/api/chat", self._build_payload(), timeout=300)
        parts, printed_thinking = [], False
        for raw in resp:
            line = raw.decode("utf-8", "replace").strip()
            if not line:
                continue
            obj = json.loads(line)
            if obj.get("error"):
                raise OllamaError(obj["error"])
            msg = obj.get("message") or {}
            thinking = msg.get("thinking")
            if thinking:
                if not printed_thinking:
                    sys.stderr.write(_c("2", "  (thinking…) ")); printed_thinking = True
                sys.stderr.write(_c("2", thinking)); sys.stderr.flush()
            chunk = msg.get("content")
            if chunk:
                if printed_thinking:
                    sys.stderr.write("\n"); printed_thinking = False
                sys.stdout.write(chunk); sys.stdout.flush()
                parts.append(chunk)
            if obj.get("done"):
                break
        sys.stdout.write("\n"); sys.stdout.flush()
        return "".join(parts)

    def respond(self, user_text):
        self.messages.append({"role": "user", "content": user_text})
        sys.stdout.write(_c("1;32", "%s: " % self.model)); sys.stdout.flush()
        try:
            content = self._stream_once()
        except OllamaError as e:
            if (self.think is not OMIT and not self.think_unsupported
                    and "think" in str(e).lower()):
                self.think_unsupported = True
                content = self._stream_once()
            else:
                self.messages.pop()
                raise
        self.messages.append({"role": "assistant", "content": content})
        self._trim()
        return content


# --------------------------------------------------------------------------- #
# Resolution helpers                                                           #
# --------------------------------------------------------------------------- #

def resolve_think(raw):
    if raw is None:
        raw = os.environ.get("OLLAMA_VOICE_THINK", "false")
    raw = (raw or "").strip().lower()
    if raw in ("", "default", "auto", "model"):
        return OMIT
    if raw in ("false", "off", "no", "0", "none"):
        return False
    if raw in ("true", "on", "yes", "1"):
        return True
    if raw in ("high", "medium", "low", "max"):
        return raw
    return False


def resolve_model(host, arg):
    if arg:
        return arg
    env = os.environ.get("OLLAMA_VOICE_MODEL")
    if env:
        return env
    models = list_models(host)
    if models:
        return models[0]
    fail("No Ollama models are installed.\n"
         "        Pull one first, e.g.:  ollama pull llama3.2\n"
         "        then run:              ollama-voice")


def resolve_lang(arg):
    return arg if arg is not None else os.environ.get("OLLAMA_VOICE_LANG", "")


def resolve_system(arg):
    if arg is not None:
        return arg
    env = os.environ.get("OLLAMA_VOICE_SYSTEM")
    return env if env is not None else DEFAULT_SYSTEM


def resolve_int(env_name, default):
    raw = (os.environ.get(env_name, "") or "").strip()
    if raw.lstrip("-").isdigit():
        n = int(raw)
        return n if n > 0 else None  # <=0 means "unlimited / disabled"
    return default


# --------------------------------------------------------------------------- #
# Sub-commands                                                                 #
# --------------------------------------------------------------------------- #

def reachable(url):
    try:
        urllib.request.urlopen(url, timeout=3).read()
        return True
    except urllib.error.HTTPError:
        return True
    except Exception:
        return False


def cmd_setup():
    """Run the repo installer (backends + this command), replacing this process."""
    here = os.path.dirname(os.path.abspath(__file__))
    for cand in (os.path.join(here, "install.sh"),
                 os.path.expanduser("~/Local-VoiceMode-LLM/integrations/ollama/install.sh")):
        if os.path.isfile(cand):
            os.execvp("bash", ["bash", cand])
    fail("install.sh not found. Clone the repo and run its installer:\n"
         "        git clone https://github.com/groxaxo/Local-VoiceMode-LLM.git\n"
         "        bash Local-VoiceMode-LLM/integrations/ollama/install.sh")


def cmd_list(host):
    if not server_up(host) and not try_start_server(host):
        fail("Ollama is not reachable at %s" % host)
    models = list_models(host)
    if not models:
        info("No models installed. Pull one with:  ollama pull llama3.2")
        return
    print("Local Ollama models:")
    for m in models:
        print("  " + m)


def cmd_status(host, talk_sh):
    ver = server_version(host)
    print(_c("1", "Ollama"))
    print("  host:      %s" % host)
    print("  server:    %s" % (("running (v%s)" % ver) if ver else "NOT running"))
    if ver:
        models = list_models(host)
        print("  models:    %s" % (", ".join(models) if models else "(none — ollama pull <model>)"))
    print(_c("1", "Voice backends"))
    print("  talk.sh:   %s" % talk_sh)
    stt = os.environ.get("STT_URL", "http://127.0.0.1:5093/v1/audio/transcriptions")
    print("  STT :5093: %s" % ("reachable" if reachable(re.sub(r"(https?://[^/]+).*", r"\1", stt)) else "NOT reachable"))
    detect_local_tts()  # resolves + prints the chosen local TTS
    eng = os.environ.get("TTS_ENGINE", "(talk.sh default)")
    url = os.environ.get("SUPERTONIC_URL", "")
    print("  TTS:       engine=%s%s" % (eng, ("  url=" + url if url else "")))
    print("\nDeeper backend check:  bash %s status" % talk_sh)


# --------------------------------------------------------------------------- #
# Main                                                                         #
# --------------------------------------------------------------------------- #

def build_parser():
    p = argparse.ArgumentParser(
        prog="ollama-voice",
        description="Hands-free spoken conversation with a local Ollama model.",
        formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("model", nargs="?", help="model to talk to (default: $OLLAMA_VOICE_MODEL or first installed)")
    p.add_argument("--setup", action="store_true", help="install/repair the voice backends + this command")
    p.add_argument("-l", "--list", action="store_true", help="list local Ollama models and exit")
    p.add_argument("--status", action="store_true", help="check Ollama + STT/TTS backends and exit")
    p.add_argument("--text", action="store_true", help="type input instead of speaking (replies still spoken)")
    p.add_argument("--once", action="store_true", help="one exchange, then exit")
    p.add_argument("--no-speak", action="store_true", help="print replies but do not synthesize them")
    p.add_argument("--lang", default=None, help="TTS language hint: en | es | '' (auto)")
    p.add_argument("--think", default=None, help="false|true|high|medium|low|default (default: false)")
    p.add_argument("--system", default=None, help="system prompt ('' = use the model's own)")
    p.add_argument("--host", default=None, help="Ollama host (default: $OLLAMA_HOST or %s)" % DEFAULT_HOST)
    return p


def main():
    args = build_parser().parse_args()

    if args.setup:
        cmd_setup()
        return

    load_env_defaults()
    host = _normalize_host(args.host or os.environ.get("OLLAMA_HOST", DEFAULT_HOST))

    if args.list:
        cmd_list(host)
        return

    talk_sh = find_talk_sh()

    if args.status:
        cmd_status(host, talk_sh)
        return

    if not server_up(host) and not try_start_server(host):
        fail("Ollama is not running and could not be started.\n"
             "        Start it in another terminal with:  ollama serve\n"
             "        (or check OLLAMA_HOST — currently %s)" % host)

    model = resolve_model(host, args.model)
    try:
        ensure_model(host, model)
    except OllamaError as e:
        fail(str(e))

    # Portable local-first TTS: find the Supertonic port on THIS machine (or NeuTTS).
    if not args.no_speak:
        detect_local_tts()

    lang = resolve_lang(args.lang)
    convo = Conversation(
        host, model,
        system=resolve_system(args.system),
        think=resolve_think(args.think),
        keep_alive=os.environ.get("OLLAMA_VOICE_KEEPALIVE") or None,
        num_predict=resolve_int("OLLAMA_VOICE_NUM_PREDICT", 400),
        history_limit=resolve_int("OLLAMA_VOICE_HISTORY", 20))

    info("Voice chat with %s — speak after the tone, Ctrl-C to exit." % _c("1", model))
    if args.text:
        info("Text input mode: type your message and press Enter.")

    silence_streak, max_silence = 0, 3
    try:
        while True:
            if args.text:
                try:
                    user_text = input(_c("1;36", "\nyou> ")).strip()
                except EOFError:
                    print(); break
            else:
                user_text = listen(talk_sh)

            if not user_text:
                if args.text:
                    continue
                silence_streak += 1
                if silence_streak >= max_silence:
                    info("No speech detected for a while — exiting. (run `ollama-voice` to resume)")
                    break
                continue
            silence_streak = 0

            if not args.text:
                sys.stdout.write(_c("1;36", "you: ") + user_text + "\n"); sys.stdout.flush()

            if is_exit_phrase(user_text):
                bye = "Goodbye!"
                sys.stdout.write(_c("1;32", "%s: " % model) + bye + "\n")
                if not args.no_speak:
                    speak(talk_sh, bye, lang)
                break

            try:
                reply = convo.respond(user_text)
            except OllamaError as e:
                warn("chat error: %s" % e)
                continue

            if not args.no_speak:
                spoken = clean_for_speech(reply)
                if spoken:
                    speak(talk_sh, spoken, lang)

            if args.once:
                break
    except KeyboardInterrupt:
        sys.stderr.write("\n"); info("Goodbye.")
        return


if __name__ == "__main__":
    main()
